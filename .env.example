# Copy this file to .env and uncomment one inference block.
# .env is gitignored; .env.example is committed.

# ---- LOCAL (llama.cpp llama-server) ----
OPENAI_BASE_URL=http://localhost:8080/v1
OPENAI_API_KEY=none
MODEL_ID=llama-3.1-8b-instruct

# ---- CLOUD (vLLM on AMD MI300X) ----
# OPENAI_BASE_URL=http://<mi300x-ip>:8000/v1
# OPENAI_API_KEY=none
# MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# ---- Wire proxy (saboteur.proxy) ----
# Where the proxy forwards (the REAL upstream). A BYO agent points its
# OPENAI_BASE_URL at the proxy (the dashboard app, http://localhost:8000/v1);
# the proxy injects faults then forwards to UPSTREAM_BASE_URL.
UPSTREAM_BASE_URL=http://localhost:8080/v1
# Auto-finish a proxy run after this many idle seconds (no requests).
PROXY_IDLE_TIMEOUT_S=120
# The externally reachable URL of THIS app (proxy mount point). The BYO cohort
# spawner gives subprocesses OPENAI_BASE_URL=<this>/v1 so their traffic routes
# back through the proxy. Change if the app isn't on localhost:8000.
PROXY_PUBLIC_BASE_URL=http://localhost:8000

# ---- Harness knobs ----
N_AGENTS=8
MAX_STEPS=15
# Per-agent wall-clock ceiling (asyncio.wait_for around the whole agent run).
# Size it to the model + concurrency, NOT just the task: injected latency /
# timeout faults and batching contention stack on top of base step time, and a
# too-low ceiling guillotines legitimately-working agents into false timeouts.
# Guidance: 8B local at N=8 ≈ 300; 70B at N=50 (e.g. MI300X over a tunnel,
# where healthy agents take 95-145s) ≈ 600. The 180 default fits fast local
# runs and the mock only.
AGENT_TIMEOUT_S=180
# Decoding determinism (invariant #1): greedy + fixed seed make two runs with
# the same profile+seed produce identical tool-call (and thus fault) sequences.
# Raise TEMPERATURE for a livelier demo at the cost of run-to-run reproducibility.
TEMPERATURE=0.0
MODEL_SEED=42
# Force a tool call at every turn via constrained generation (llama.cpp --jinja,
# vLLM). Set TOOL_CHOICE=auto if a future backend rejects the parameter.
TOOL_CHOICE=required
# Max agents running at once (0 = unlimited). Keep at 8 locally to match
# llama.cpp's -np 8 slots; set 0 (or 50) on the MI300X.
CONCURRENCY_LIMIT=8

# ---- Ports / split deployments ----
# scripts/dev.sh + scripts/run_local.sh honor API_PORT (uvicorn, default 8000)
# and LLM_PORT (llama-server, default 8080) — e.g. when an SSH tunnel owns
# :8000. If you move the API off :8000, also set OPENAI_BASE_URL /
# UPSTREAM_BASE_URL / PROXY_PUBLIC_BASE_URL above to match, and point the
# frontend at it with VITE_API_BASE_URL (read by the Vite dev proxy AND baked
# into static builds; unset = same-origin, which is right when FastAPI serves
# frontend/dist itself).
# API_PORT=8000
# LLM_PORT=8080
# VITE_API_BASE_URL=http://localhost:8000

# Path to the local GGUF — read by scripts/run_local.sh, not by the Python package.
# Download: bartowski/Meta-Llama-3.1-8B-Instruct-GGUF → *Q4_K_M.gguf from Hugging Face.
# MODEL_GGUF=/path/to/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
