# Claude Code / assistant tooling — keep everything non-project out of the repo.
CLAUDE.md
.claude/
.claude.json
.mcp.json

# Local env (secrets / host-specific). Only .env.example is committed.
.env

# Run artifacts stay local (the SQLite index is rebuildable from the JSONL).
# Only the golden offline demo run is tracked — it drives `saboteur replay`
# on a fresh clone with no inference.
runs/*
!runs/.gitkeep
!runs/hell_mode-20260629T231833-2b225c.jsonl
!runs/hell_mode-20260629T231833-2b225c-control.jsonl
!runs/hell_mode-20260629T231833-2b225c.scorecard.json

# Python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
.venv-verify/
.ruff_cache/
.mypy_cache/

# Node / frontend build (dependencies + generated artifacts — never commit)
node_modules/
frontend/node_modules/
frontend/dist/
.vite/
*.tsbuildinfo

# Logs
*.log

# Local run guide — stays untracked; the README carries the running instructions.
RUNNING.md
