runs/saboteur.db
runs/saboteur.db-wal
runs/saboteur.db-shm

# Python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
.venv-verify/
.ruff_cache/
.mypy_cache/

# Node / frontend build (dependencies + generated artifacts — never commit)
node_modules/
frontend/node_modules/
frontend/dist/
.vite/
*.tsbuildinfo

# Logs
*.log
