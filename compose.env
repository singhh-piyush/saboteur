# Docker-stack environment (no secrets — safe to commit).
#
# Passed to `docker compose --env-file compose.env ...` (what `make up` uses).
# Using a dedicated file decouples the container from the host `.env`, which
# sets OPENAI_BASE_URL=http://localhost:8080/v1 for host-side tools — wrong
# inside a container, where llama.cpp lives on the HOST, reached by name.
#
# Override any value in your shell (shell env wins over this file).

# ---- Inference: host llama.cpp (must be started with --host 0.0.0.0) ----
OPENAI_BASE_URL=http://host.docker.internal:8080/v1
OPENAI_API_KEY=none
MODEL_ID=llama-3.1-8b-instruct

# ---- Wire proxy upstream (the real backend the proxy forwards to) ----
UPSTREAM_BASE_URL=http://host.docker.internal:8080/v1
PROXY_IDLE_TIMEOUT_S=120
# BYO subprocesses run inside the container → loop back to our own uvicorn.
PROXY_PUBLIC_BASE_URL=http://localhost:8000

# ---- Harness knobs ----
N_AGENTS=8
MAX_STEPS=15
AGENT_TIMEOUT_S=300
TEMPERATURE=0.3
MODEL_SEED=42
TOOL_CHOICE=required
CONCURRENCY_LIMIT=8

# ---- CLOUD swap (post-deadline): comment the two host.docker.internal lines
# above and uncomment these, pointed at the MI300X vLLM endpoint ----
# OPENAI_BASE_URL=http://<mi300x-ip>:8000/v1
# UPSTREAM_BASE_URL=http://<mi300x-ip>:8000/v1
# MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
# CONCURRENCY_LIMIT=0
